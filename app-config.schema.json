{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "app": {
      "type": "object",
      "properties": {
        "signInPage": {
          "type": "string",
          "enum": ["guest", "github"],
          "visibility": "frontend"
        }
      }
    },
    "auth": {
      "type": "object",
      "properties": {
        "githubAccess": {
          "type": "object",
          "properties": {
            "allowedDomains": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "whitelistedEmails": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
